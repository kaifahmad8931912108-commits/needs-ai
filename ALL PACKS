      alert("Payment Gateway loading... Please try again in 3 seconds.");
      return;
    }

    const options = {
      key: RAZORPAY_KEY_ID,
      amount: amountInINR * 100, // ₹599 = 59900 paise
      currency: "INR",
      name: "ALLPACK Studio",
      description: "PRO Membership Upgrade",
      handler: function (response) {
        if (response.razorpay_payment_id) {
          localStorage.setItem('ALLPACK_PRO_USER_VERIFIED', 'true');
          isProUser = true;
          checkProUserStatus();
          alert("✓ Payment Successful! PRO Features & Custom PBR Downloads Unlocked.");
          closePricingModal();
        }
      },
      theme: { color: "#10b981" }
    };

    const rzp = new Razorpay(options);
    rzp.open();
  }

  // Fetch PolyHaven Textures
  async function loadPolyHavenTextures() {
    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 6000);

      const response = await fetch('https://api.polyhaven.com/assets?t=textures', { signal: controller.signal });
      clearTimeout(timeoutId);

      const data = await response.json();

      allTexturesData = Object.keys(data).map(key => ({
        id: key,
        name: data[key].name || key.replace(/_/g, ' '),
        categories: data[key].categories || [],
        thumbnail: `https://cdn.polyhaven.com/asset_img/thumbs/${key}.png?width=256&height=256`,
        type: 'texture'
      }));

      document.getElementById('cat-count-all').innerText = allTexturesData.length;
    } catch (err) {
      console.warn("PolyHaven API Timeout or Error, using instant fallbacks:", err);
      allTexturesData = FALLBACK_TEXTURES;
      document.getElementById('cat-count-all').innerText = allTexturesData.length;
    } finally {
      document.getElementById('loading-spinner').classList.add('hidden');
      document.getElementById('asset-grid').classList.remove('hidden');
      if (activeMode === 'textures') renderGrid(allTexturesData);
    }
  }

  // Fetch Sketchfab 3D Models
  async function loadSketchfabModels(query = '3d model', cursor = '') {
    try {
      document.getElementById('loading-spinner').classList.remove('hidden');
      document.getElementById('asset-grid').classList.add('hidden');

      let fetchUrl = `https://api.sketchfab.com/v3/search?type=models&q=${encodeURIComponent(query)}&downloadable=true&count=30`;
      if (cursor) fetchUrl += `&cursor=${cursor}`;

      const response = await fetch(fetchUrl);
      const data = await response.json();
      currentCursor = data.cursors ? data.cursors.next : null;

      const newModels = (data.results || []).map(item => ({
        id: item.uid,
        name: item.name,
        thumbnail: item.thumbnails && item.thumbnails.images && item.thumbnails.images[2] ? item.thumbnails.images[2].url : 'https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=300&q=80',
        url: item.viewerUrl,
        embedUrl: item.embedUrl,
        type: 'model'
      }));

      if (cursor) {
        allModelsData = [...allModelsData, ...newModels];
      } else {
        allModelsData = newModels;
      }
    } catch (err) {
      console.error("Sketchfab API Error:", err);
    } finally {
      document.getElementById('loading-spinner').classList.add('hidden');
      document.getElementById('asset-grid').classList.remove('hidden');
      document.getElementById('load-more-box').classList.remove('hidden');
      if (activeMode === 'models') renderGrid(allModelsData);
    }
  }

  function loadMoreAssets() {
    if (activeMode === 'models') {
      loadSketchfabModels('3d model', currentCursor);
    }
  }

  function renderGrid(items) {
    const grid = document.getElementById('asset-grid');
    grid.innerHTML = '';

    if (!items || items.length === 0) {
      grid.innerHTML = `<div class="col-span-full text-center py-10 text-slate-500 text-xs">No assets found. Try searching something else.</div>`;
      return;
    }

    items.forEach((item, idx) => {
      const card = document.createElement('div');
      card.className = "asset-card cursor-pointer group flex flex-col items-center text-center p-3.5 rounded-2xl glass-card transition-all duration-300 animate-fade-in-up";
      card.style.animationDelay = `${Math.min(idx * 20, 300)}ms`;
      card.onclick = () => openDlModal(item);

      card.innerHTML = `
        <div class="w-28 h-28 sm:w-32 sm:h-32 texture-sphere overflow-hidden relative mb-3 bg-slate-950 border border-slate-800/60">
          <img src="${item.thumbnail}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" onerror="this.src='https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&w=300&q=80'">
        </div>
        <h3 class="text-xs font-bold text-slate-200 group-hover:text-brand-400 transition-colors duration-200 line-clamp-1 capitalize">${item.name}</h3>
      `;
      grid.appendChild(card);
    });
  }

  function switchAssetType(mode, btn) {
    activeMode = mode;
    document.getElementById('tab-textures').className = "py-2 rounded-lg text-xs font-medium text-slate-400 hover:text-white transition flex items-center justify-center gap-1.5 hover:bg-slate-900/50";
    document.getElementById('tab-models').className = "py-2 rounded-lg text-xs font-medium text-slate-400 hover:text-white transition flex items-center justify-center gap-1.5 hover:bg-slate-900/50";

    btn.className = "py-2 rounded-lg text-xs font-bold bg-gradient-to-r from-emerald-500 to-emerald-600 text-slate-950 transition flex items-center justify-center gap-1.5 shadow-md";

    if (mode === 'textures') {
      document.getElementById('current-category-name').innerText = "All PBR Textures";
      document.getElementById('load-more-box').classList.add('hidden');
      renderGrid(allTexturesData);
    } else {
      document.getElementById('current-category-name').innerText = "Sketchfab 3D Models";
      if (allModelsData.length === 0) {
        loadSketchfabModels('3d model');
      } else {
        renderGrid(allModelsData);
        document.getElementById('load-more-box').classList.remove('hidden');
      }
    }
  }

  function filterCategory(cat, btn) {
    document.querySelectorAll('.sidebar-btn').forEach(b => {
      b.className = "sidebar-btn w-full text-left px-3.5 py-2.5 rounded-xl hover:bg-slate-900/80 text-slate-400 hover:text-white flex items-center justify-between transition-all duration-200";
    });
    btn.className = "sidebar-btn active-cat w-full text-left px-3.5 py-2.5 rounded-xl bg-brand-500/10 text-brand-400 border border-brand-500/30 font-bold flex items-center justify-between transition-all duration-300";

    document.getElementById('current-category-name').innerText = cat === 'all' ? 'All Assets' : cat.toUpperCase();

    if (activeMode === 'textures') {
      if (cat === 'all') renderGrid(allTexturesData);
      else renderGrid(allTexturesData.filter(item => item.categories && item.categories.includes(cat)));
    } else {
      loadSketchfabModels(cat);
    }
  }

  document.getElementById('asset-search').addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();
    if (activeMode === 'textures') {
      renderGrid(allTexturesData.filter(item => item.name.toLowerCase().includes(q)));
    } else {
      if (q.length > 2) loadSketchfabModels(q);
    }
  });

  async function openDlModal(item) {
    currentSelectedItem = item;
    document.getElementById('modal-title').innerText = item.name;
    document.getElementById('modal-img').src = item.thumbnail;

    let monetizedUrl = item.url;
    if (item.type === 'model') {
      monetizedUrl = `${item.url}?ref=${AFFILIATE_CONFIG.sketchfabRefId}`;
    } else {
      monetizedUrl = `https://polyhaven.com/a/${item.id}`;
    }

    document.getElementById('modal-source').innerText = item.type === 'texture' ? "PolyHaven CC0 Texture" : "Sketchfab 3D Model";
    document.getElementById('modal-page-url').innerText = monetizedUrl;
    document.getElementById('modal-page-url').href = monetizedUrl;
    document.getElementById('modal-web-btn').href = monetizedUrl;

    const embedBox = document.getElementById('sketchfab-embed-box');
    const iframe = document.getElementById('sketchfab-iframe');
    if (item.type === 'model' && item.embedUrl) {
      iframe.src = `${item.embedUrl}/embed`;
      embedBox.classList.remove('hidden');
    } else {
      embedBox.classList.add('hidden');
      iframe.src = '';
    }

    await updateDownloadLink();
    document.getElementById('dl-modal').classList.remove('hidden');
  }

  function closeDlModal() {
    document.getElementById('sketchfab-iframe').src = '';
    document.getElementById('dl-modal').classList.add('hidden');
  }

  async function setResolution(res, btn) {
    if (res === '4k' && !isProUser) {
      openPricingModal();
      return;
    }

    currentRes = res;
    document.querySelectorAll('.res-btn').forEach(b => {
      b.className = "res-btn bg-slate-950 border border-slate-800 py-2 rounded-xl text-xs font-mono text-slate-300 hover:border-brand-500";
    });
    btn.className = "res-btn bg-brand-500 text-slate-950 font-bold border border-brand-500 py-2 rounded-xl text-xs font-mono";

    await updateDownloadLink();
  }

  async function updateDownloadLink() {
    const dlBtn = document.getElementById('modal-download-link');
    if (!currentSelectedItem) return;

    if (currentSelectedItem.type === 'model') {
      dlBtn.href = `${currentSelectedItem.url}?ref=${AFFILIATE_CONFIG.sketchfabRefId}`;
      dlBtn.innerHTML = `<i class="fa-solid fa-download"></i> Get 3D Model`;
    } else {
      dlBtn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Resolving Link...`;
      try {
        const res = await fetch(`https://api.polyhaven.com/files/${currentSelectedItem.id}`);
        const filesData = await res.json();

        if (filesData && filesData.zip && filesData.zip[currentRes]) {
          const formatKey = Object.keys(filesData.zip[currentRes])[0];
          dlBtn.href = filesData.zip[currentRes][formatKey].url;
        } else {
          dlBtn.href = `https://polyhaven.com/a/${currentSelectedItem.id}`;
        }
      } catch (e) {
        dlBtn.href = `https://polyhaven.com/a/${currentSelectedItem.id}`;
      }
      dlBtn.innerHTML = `<i class="fa-solid fa-download"></i> Get Zip Package`;
    }
  }

  // Custom PBR Generator Engine & Three.js 3D Viewport
  let customImg = new Image();
  customImg.crossOrigin = "anonymous";

  let scene, camera, renderer, controls, meshMaterial, currentMesh;

  function initThreeJS() {
    const container = document.getElementById('three-canvas-container');
    if (!container) return;

    try {
      scene = new THREE.Scene();
      camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
      camera.position.set(0, 0, 4.5);

      renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setSize(container.clientWidth, container.clientHeight);
      renderer.setPixelRatio(window.devicePixelRatio);
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      container.appendChild(renderer.domElement);

      controls = new THREE.OrbitControls(camera, renderer.domElement);
      controls.enableDamping = true;
      controls.dampingFactor = 0.05;
      controls.autoRotate = true;
      controls.autoRotateSpeed = 1.5;

      const ambientLight = new THREE.AmbientLight(0xffffff, 0.8);
      scene.add(ambientLight);

      const dirLight1 = new THREE.DirectionalLight(0xffffff, 1.2);
      dirLight1.position.set(5, 10, 7);
      scene.add(dirLight1);

      meshMaterial = new THREE.MeshStandardMaterial({ roughness: 0.5, metalness: 0.1 });
      changeMeshShape('sphere');

      window.addEventListener('resize', onWindowResize);
      animateThree();
    } catch(e) {
      console.error("Three.js init error:", e);
    }
  }

  // 📦 CUSTOM .OBJ FILE UPLOAD & PREVIEW LOGIC
  function handleObjUpload(e) {
    const file = e.target.files[0];
    if (!file) return;
    loadObjFile(file);
  }

  function setupObjDragAndDrop() {
    const viewport = document.getElementById('studio-view-3d');
    if (!viewport) return;

    viewport.addEventListener('dragover', (e) => {
      e.preventDefault();
      viewport.classList.add('border-brand-500');
    });

    viewport.addEventListener('dragleave', () => {
      viewport.classList.remove('border-brand-500');
    });

    viewport.addEventListener('drop', (e) => {
      e.preventDefault();
      viewport.classList.remove('border-brand-500');
      if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
        const file = e.dataTransfer.files[0];
        if (file.name.toLowerCase().endsWith('.obj')) {
          loadObjFile(file);
        } else {
          alert('Please drop a valid .OBJ file!');
        }
      }
    });
  }

  function loadObjFile(file) {
    const reader = new FileReader();
    reader.onload = function(event) {
      try {
        const loader = new THREE.OBJLoader();
        const object = loader.parse(event.target.result);

        if (currentMesh) scene.remove(currentMesh);

        object.traverse((child) => {
          if (child.isMesh) {
            child.material = meshMaterial;
          }
        });

        // Auto-center and auto-scale custom OBJ model
        const box = new THREE.Box3().setFromObject(object);
        const center = box.getCenter(new THREE.Vector3());
        const size = box.getSize(new THREE.Vector3());
        const maxDim = Math.max(size.x, size.y, size.z);
        const scale = 2.5 / (maxDim || 1);
        object.scale.set(scale, scale, scale);
        object.position.sub(center.multiplyScalar(scale));

        currentMesh = object;
        scene.add(currentMesh);

        // Update active button states
        document.querySelectorAll('.shape-btn').forEach(btn => {
          btn.className = "shape-btn px-2.5 py-1 rounded-lg text-slate-400 hover:bg-slate-800 hover:text-white transition";
        });
        alert(`✓ 3D Model (${file.name}) loaded successfully! Applied texture map.`);
      } catch(err) {
        alert('Error loading OBJ file: ' + err.message);
      }
    };
    reader.readAsText(file);
  }

  function animateThree() {
    requestAnimationFrame(animateThree);
    if (controls) controls.update();
    if (renderer && scene && camera) renderer.render(scene, camera);
  }

  function onWindowResize() {
    const container = document.getElementById('three-canvas-container');
    if (!container || !renderer || !camera) return;
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(container.clientWidth, container.clientHeight);
  }

  function changeMeshShape(type) {
    if (!scene) return;
    if (currentMesh) scene.remove(currentMesh);

    let geometry;
    switch (type) {
      case 'cube': geometry = new THREE.BoxGeometry(2, 2, 2); break;
      case 'plane': geometry = new THREE.PlaneGeometry(3, 3); break;
      case 'cylinder': geometry = new THREE.CylinderGeometry(1.2, 1.2, 2.5, 32); break;
      case 'torus': geometry = new THREE.TorusKnotGeometry(1, 0.35, 100, 16); break;
      case 'sphere': default: geometry = new THREE.SphereGeometry(1.5, 64, 64); break;
    }

    currentMesh = new THREE.Mesh(geometry, meshMaterial);
    scene.add(currentMesh);

    document.querySelectorAll('.shape-btn').forEach(btn => {
      btn.className = "shape-btn px-2.5 py-1 rounded-lg text-slate-400 hover:bg-slate-800 hover:text-white transition";
    });
    const activeBtn = document.getElementById(`shape-${type}`);
    if (activeBtn) activeBtn.className = "shape-btn px-2.5 py-1 rounded-lg bg-slate-800 text-brand-400 border border-brand-500/40 hover:text-white transition";
  }

  function toggleStudioTab(tab) {
    const btn3d = document.getElementById('tab-btn-3d');
    const btnCh = document.getElementById('tab-btn-channels');
    const view3d = document.getElementById('studio-view-3d');
    const viewCh = document.getElementById('studio-view-channels');

    if (tab === '3d') {
      btn3d.className = "px-4 py-1.5 rounded-lg text-xs font-bold bg-brand-500 text-slate-950 transition flex items-center gap-1.5 shadow-md";
      btnCh.className = "px-4 py-1.5 rounded-lg text-xs font-medium text-slate-400 hover:text-white transition flex items-center gap-1.5";
      view3d.classList.remove('hidden');
      viewCh.classList.add('hidden');
      onWindowResize();
    } else {
      btnCh.className = "px-4 py-1.5 rounded-lg text-xs font-bold bg-brand-500 text-slate-950 transition flex items-center gap-1.5 shadow-md";
      btn3d.className = "px-4 py-1.5 rounded-lg text-xs font-medium text-slate-400 hover:text-white transition flex items-center gap-1.5";
      viewCh.classList.remove('hidden');
      view3d.classList.add('hidden');
    }
  }

  function handleFileSelect(e) {
    if (e.target.files.length > 0) {
      const reader = new FileReader();
      reader.onload = (ev) => {
        customImg = new Image();
        customImg.onload = () => {
          document.getElementById('custom-name').value = e.target.files[0].name.split('.')[0].replace(/[^a-zA-Z0-9]/g, '_');
          processCustomMaps();
        };
        customImg.src = ev.target.result;
      };
      reader.readAsDataURL(e.target.files[0]);
    }
  }

  function processCustomMaps() {
    if (!customImg.complete) return;
    const size = 256;

    const rVal = document.getElementById('rough-slider').value;
    const bVal = document.getElementById('bump-slider').value;
    document.getElementById('rough-val').innerText = `${rVal}%`;
    document.getElementById('bump-val').innerText = `${bVal}%`;

    const cDiff = setupCvs('c-diffuse', size);
    cDiff.ctx.drawImage(customImg, 0, 0, size, size);
    const pixels = cDiff.ctx.getImageData(0, 0, size, size).data;

    const cRough = setupCvs('c-roughness', size);
    const cBump = setupCvs('c-bump', size);
    const cNorm = setupCvs('c-normal', size);
    const cDisp = setupCvs('c-displacement', size);
    const cMet = setupCvs('c-metallic', size);

    const imgR = cRough.ctx.createImageData(size, size);
    const imgB = cBump.ctx.createImageData(size, size);
    const imgN = cNorm.ctx.createImageData(size, size);
    const imgD = cDisp.ctx.createImageData(size, size);
    const imgM = cMet.ctx.createImageData(size, size);

    for (let i = 0; i < pixels.length; i += 4) {
      const gray = 0.299 * pixels[i] + 0.587 * pixels[i+1] + 0.114 * pixels[i+2];

      let r = Math.min(255, Math.max(0, (gray - 128) * (rVal / 50) + 128));
      imgR.data[i] = imgR.data[i+1] = imgR.data[i+2] = r; imgR.data[i+3] = 255;

      let b = Math.min(255, Math.max(0, gray * (bVal / 50)));
      imgB.data[i] = imgB.data[i+1] = imgB.data[i+2] = b; imgB.data[i+3] = 255;
      imgD.data[i] = imgD.data[i+1] = imgD.data[i+2] = b; imgD.data[i+3] = 255;

      imgM.data[i] = imgM.data[i+1] = imgM.data[i+2] = 0; imgM.data[i+3] = 255;
      imgN.data[i] = 128; imgN.data[i+1] = 128; imgN.data[i+2] = 255 - (b * 0.4); imgN.data[i+3] = 255;
    }

    cRough.ctx.putImageData(imgR, 0, 0);
    cBump.ctx.putImageData(imgB, 0, 0);
    cNorm.ctx.putImageData(imgN, 0, 0);
    cDisp.ctx.putImageData(imgD, 0, 0);
    cMet.ctx.putImageData(imgM, 0, 0);

    if (meshMaterial) {
      meshMaterial.map = new THREE.CanvasTexture(cDiff.cvs);
      meshMaterial.normalMap = new THREE.CanvasTexture(cNorm.cvs);
      meshMaterial.roughnessMap = new THREE.CanvasTexture(cRough.cvs);
      meshMaterial.roughness = parseFloat(rVal) / 100;
      meshMaterial.needsUpdate = true;
    }
  }

  function setupCvs(id, size) {
    const cvs = document.getElementById(id);
    cvs.width = size; cvs.height = size;
    return { cvs, ctx: cvs.getContext('2d') };
  }

  // 🔒 STRICT PRO-PROTECTED CUSTOM ZIP DOWNLOAD
  async function downloadCustomZip() {
    // Direct Lock Gate: Open Razorpay Payment Modal if user is not PRO
    if (!isProUser) {
      openPricingModal();
      return; // Absolute Halt
    }

    const zip = new JSZip();
    const name = document.getElementById('custom-name').value || 'Custom_Texture';
    const folder = zip.folder(name);

    const btn = document.getElementById('custom-zip-btn');
    btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Zipping PBR Maps...`;

    const list = [
      { id: 'c-diffuse', file: `${name}_Diffuse.png` },
      { id: 'c-roughness', file: `${name}_Roughness.png` },
      { id: 'c-bump', file: `${name}_Bump.png` },
      { id: 'c-normal', file: `${name}_Normal.png` },
      { id: 'c-displacement', file: `${name}_Displacement.png` }
    ];

    for (const item of list) {
      const cvs = document.getElementById(item.id);
      const blob = await (await fetch(cvs.toDataURL())).blob();
      folder.file(item.file, blob);
    }

    zip.generateAsync({ type: 'blob' }).then(content => {
      const a = document.createElement('a');
      a.href = URL.createObjectURL(content);
      a.download = `${name}_PBR_Package.zip`;
      a.click();
      btn.innerHTML = `<i class="fa-solid fa-file-zipper"></i> Download Generated Maps (.ZIP)`;
    });
  }
