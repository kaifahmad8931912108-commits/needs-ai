<!DOCTYPE html>
<html lang="en" class="dark scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ALLPACK — Luxury Studio Asset Platform</title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- FontAwesome 6 Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  <!-- JSZip CDN for custom generated texture download -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

  <!-- Three.js CDN & OBJLoader for Realtime 3D Viewport & Custom OBJ Imports -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/OBJLoader.js"></script>

  <!-- 💳 OFFICIAL RAZORPAY PAYMENT GATEWAY SDK -->
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

  <!-- Google Fonts: Plus Jakarta Sans & Space Grotesk -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">

  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['"Plus Jakarta Sans"', 'sans-serif'],
            display: ['"Space Grotesk"', 'sans-serif'],
          },
          colors: {
            brand: {
              400: '#34d399',
              500: '#10b981',
              600: '#059669',
            }
          },
          animation: {
            'glow-pulse': 'glowPulse 4s ease-in-out infinite alternate',
            'fade-in-up': 'fadeInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards',
          },
          keyframes: {
            glowPulse: {
              '0%': { filter: 'drop-shadow(0 0 15px rgba(16, 185, 129, 0.2))' },
              '100%': { filter: 'drop-shadow(0 0 35px rgba(16, 185, 129, 0.6))' },
            },
            fadeInUp: {
              '0%': { opacity: '0', transform: 'translateY(15px)' },
              '100%': { opacity: '1', transform: 'translateY(0)' },
            }
          }
        }
      }
    }
  </script>

  <style>
    body {
      background-color: #030508;
      color: #f1f5f9;
      background-image:
        radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.12) 0px, transparent 45%),
        radial-gradient(at 100% 0%, rgba(245, 158, 11, 0.08) 0px, transparent 50%),
        radial-gradient(at 50% 50%, rgba(6, 182, 212, 0.04) 0px, transparent 60%),
        radial-gradient(at 50% 100%, rgba(3, 5, 8, 0.98) 0px, transparent 70%);
      background-attachment: fixed;
    }

    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: #020305; }
    ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #10b981; }

    .logo-gradient-text {
      background: linear-gradient(135deg, #ffffff 0%, #a7f3d0 35%, #fef08a 70%, #10b981 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      filter: drop-shadow(0 2px 10px rgba(16, 185, 129, 0.2));
    }

    .logo-icon-bg {
      background: linear-gradient(135deg, #059669 0%, #10b981 50%, #f59e0b 100%);
      box-shadow: 0 0 30px rgba(16, 185, 129, 0.4), inset 0 0 10px rgba(255,255,255,0.4);
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .glass-header {
      background: rgba(3, 5, 8, 0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .glass-sidebar {
      background: rgba(6, 9, 15, 0.85);
      backdrop-filter: blur(20px);
      border-right: 1px solid rgba(255, 255, 255, 0.05);
    }

    .glass-card {
      background: linear-gradient(145deg, rgba(15, 23, 42, 0.4) 0%, rgba(11, 15, 25, 0.6) 100%);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.05);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .glass-card:hover {
      border-color: rgba(16, 185, 129, 0.5);
      background: linear-gradient(145deg, rgba(20, 30, 50, 0.7) 0%, rgba(13, 20, 35, 0.8) 100%);
      transform: translateY(-6px) scale(1.02);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.7), 0 0 30px rgba(16, 185, 129, 0.2);
    }

    .texture-sphere {
      border-radius: 50%;
      box-shadow: inset -14px -14px 28px rgba(0,0,0,0.95), inset 8px 8px 18px rgba(255,255,255,0.3), 0 15px 30px rgba(0,0,0,0.8);
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .asset-card:hover .texture-sphere {
      transform: scale(1.12) rotate(4deg);
      box-shadow: inset -10px -10px 22px rgba(0,0,0,0.9), inset 6px 6px 14px rgba(255,255,255,0.5), 0 22px 45px rgba(16, 185, 129, 0.35);
    }

    input[type=range] {
      -webkit-appearance: none;
      background: #0f172a;
      height: 6px;
      border-radius: 3px;
    }
    input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none;
      height: 18px;
      width: 18px;
      border-radius: 50%;
      background: #10b981;
      cursor: pointer;
      box-shadow: 0 0 12px rgba(16, 185, 129, 0.7);
      transition: all 0.2s ease;
    }
    input[type=range]::-webkit-slider-thumb:hover {
      transform: scale(1.2);
      background: #34d399;
    }

    .btn-glow {
      position: relative;
      overflow: hidden;
    }
    .btn-glow::after {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: linear-gradient(60deg, transparent, rgba(255,255,255,0.2), transparent);
      transform: rotate(30deg);
      transition: transform 0.8s ease;
    }
    .btn-glow:hover::after {
      transform: rotate(30deg) translate(100%, 100%);
    }
  </style>
</head>
<body class="font-sans antialiased min-h-screen flex flex-col selection:bg-brand-500 selection:text-slate-950">

<!-- ================= TOP HEADER ================= -->
<header class="h-16 glass-header sticky top-0 z-40 flex items-center justify-between px-4 sm:px-8">
  <div class="flex items-center gap-3">
    <a href="#" class="flex items-center gap-3 font-display font-bold text-xl tracking-wider text-white group">
      <div class="w-10 h-10 rounded-xl logo-icon-bg flex items-center justify-center text-slate-950 font-black text-xl group-hover:scale-110 group-hover:rotate-6 transition duration-300">
        <i class="fa-solid fa-cube text-slate-950 text-lg"></i>
      </div>
      <span class="logo-gradient-text text-2xl font-extrabold tracking-tight">ALLPACK</span>
    </a>
  </div>

  <!-- AI Tools Header Links -->
  <div class="hidden lg:flex items-center gap-2 text-[11px] font-mono">
    <span class="text-xs text-brand-400 font-bold uppercase mr-1"><i class="fa-solid fa-robot mr-1"></i> AI Tools:</span>
    <a href="https://chatgpt.com" target="_blank" class="px-2.5 py-1 rounded-lg bg-slate-900 border border-slate-800 hover:border-brand-500 text-slate-300 hover:text-white transition flex items-center gap-1.5"><i class="fa-solid fa-bolt text-amber-400 text-[10px]"></i> ChatGPT</a>
    <a href="https://gemini.google.com" target="_blank" class="px-2.5 py-1 rounded-lg bg-slate-900 border border-slate-800 hover:border-brand-500 text-slate-300 hover:text-white transition flex items-center gap-1.5"><i class="fa-solid fa-sparkles text-blue-400 text-[10px]"></i> Gemini</a>
    <a href="https://claude.ai" target="_blank" class="px-2.5 py-1 rounded-lg bg-slate-900 border border-slate-800 hover:border-brand-500 text-slate-300 hover:text-white transition flex items-center gap-1.5"><i class="fa-solid fa-brain text-purple-400 text-[10px]"></i> Claude</a>
    <a href="https://www.midjourney.com" target="_blank" class="px-2.5 py-1 rounded-lg bg-slate-900 border border-slate-800 hover:border-brand-500 text-slate-300 hover:text-white transition flex items-center gap-1.5"><i class="fa-solid fa-image text-emerald-400 text-[10px]"></i> Midjourney</a>
    <a href="https://leonardo.ai" target="_blank" class="px-2.5 py-1 rounded-lg bg-slate-900 border border-slate-800 hover:border-brand-500 text-slate-300 hover:text-white transition flex items-center gap-1.5"><i class="fa-solid fa-palette text-rose-400 text-[10px]"></i> Leonardo AI</a>
  </div>

  <!-- HEADER BUTTONS -->
  <div class="flex items-center gap-3 text-xs font-semibold">
    <button onclick="openPricingModal()" class="btn-glow bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-slate-950 font-bold px-4 py-2 rounded-xl transition-all duration-300 flex items-center gap-2 shadow-lg shadow-amber-500/20">
      <i class="fa-solid fa-crown text-slate-950 text-xs"></i>
      <span id="user-status-btn">Upgrade to PRO</span>
    </button>

    <button onclick="openContactModal()" class="btn-glow bg-gradient-to-r from-slate-800 to-slate-900 hover:from-slate-700 hover:to-slate-800 text-slate-200 border border-slate-700 hover:border-brand-500/50 font-bold px-4 py-2 rounded-xl transition-all duration-300 flex items-center gap-1.5 shadow-lg shadow-slate-950/50">
      <i class="fa-solid fa-headset text-[11px] text-brand-400"></i> Contact Us
    </button>
  </div>
</header>

<!-- ================= MAIN LAYOUT ================= -->
<div class="flex-grow flex w-full">

  <!-- LEFT SIDEBAR -->
  <aside class="w-64 glass-sidebar p-4 shrink-0 hidden md:flex flex-col justify-between select-none max-h-[calc(100vh-4rem)] sticky top-16 overflow-y-auto">

    <div>
      <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-3 px-2 flex items-center gap-1.5">
        <i class="fa-solid fa-sliders text-[9px]"></i> Asset Switcher
      </div>

      <div class="grid grid-cols-2 gap-1.5 mb-6 p-1 bg-slate-950/90 rounded-xl border border-slate-800/80 shadow-inner">
        <button onclick="switchAssetType('textures', this)" id="tab-textures" class="py-2 rounded-lg text-xs font-bold bg-gradient-to-r from-emerald-500 to-emerald-600 text-slate-950 transition-all duration-300 flex items-center justify-center gap-1.5 shadow-md">
          <i class="fa-solid fa-chess-board text-xs"></i> Textures
        </button>
        <button onclick="switchAssetType('models', this)" id="tab-models" class="py-2 rounded-lg text-xs font-medium text-slate-400 hover:text-white transition-all duration-300 flex items-center justify-center gap-1.5 hover:bg-slate-900/50">
          <i class="fa-solid fa-cube text-xs"></i> 3D Models
        </button>
      </div>

      <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-3 px-2 flex items-center gap-1.5">
        <i class="fa-solid fa-folder-tree text-[9px]"></i> Categories
      </div>

      <nav class="space-y-1.5 text-xs text-slate-300" id="sidebar-categories">
        <button onclick="filterCategory('all', this)" class="sidebar-btn active-cat w-full text-left px-3.5 py-2.5 rounded-xl bg-brand-500/10 text-brand-400 border border-brand-500/30 font-bold flex items-center justify-between transition-all duration-300">
          <span><i class="fa-solid fa-layer-group text-[10px] mr-2"></i> All Assets</span>
          <span class="text-[10px] bg-slate-950 border border-slate-800 px-2 py-0.5 rounded-md text-slate-400 font-mono" id="cat-count-all">...</span>
        </button>
        <button onclick="filterCategory('brick', this)" class="sidebar-btn w-full text-left px-3.5 py-2.5 rounded-xl hover:bg-slate-900/80 text-slate-400 hover:text-white flex items-center justify-between transition-all duration-200">
          <span><i class="fa-solid fa-chevron-right text-[9px] mr-2 text-slate-600"></i> Brick</span>
        </button>
        <button onclick="filterCategory('wood', this)" class="sidebar-btn w-full text-left px-3.5 py-2.5 rounded-xl hover:bg-slate-900/80 text-slate-400 hover:text-white flex items-center justify-between transition-all duration-200">
          <span><i class="fa-solid fa-chevron-right text-[9px] mr-2 text-slate-600"></i> Wood</span>
        </button>
        <button onclick="filterCategory('concrete', this)" class="sidebar-btn w-full text-left px-3.5 py-2.5 rounded-xl hover:bg-slate-900/80 text-slate-400 hover:text-white flex items-center justify-between transition-all duration-200">
          <span><i class="fa-solid fa-chevron-right text-[9px] mr-2 text-slate-600"></i> Concrete</span>
        </button>
        <button onclick="filterCategory('metal', this)" class="sidebar-btn w-full text-left px-3.5 py-2.5 rounded-xl hover:bg-slate-900/80 text-slate-400 hover:text-white flex items-center justify-between transition-all duration-200">
          <span><i class="fa-solid fa-chevron-right text-[9px] mr-2 text-slate-600"></i> Metal</span>
        </button>
      </nav>

      <!-- PRO EXCLUSIVE TOOLS -->
      <div class="mt-6 pt-4 border-t border-slate-800/80">
        <div class="text-[10px] font-bold uppercase tracking-widest text-amber-400 mb-2 px-2 flex items-center justify-between">
          <span><i class="fa-solid fa-crown text-[9px] mr-1"></i> Pro Tools</span>
          <span class="text-[9px] bg-amber-500/20 text-amber-300 border border-amber-500/40 px-1.5 py-0.5 rounded">PRO</span>
        </div>
        <div class="space-y-1 text-xs">
          <button onclick="triggerProFeature('Batch Download')" class="w-full text-left flex items-center justify-between p-2 rounded-lg hover:bg-slate-900 text-slate-400 hover:text-amber-400 transition">
            <span><i class="fa-solid fa-boxes-packing text-[10px] mr-1.5"></i> Batch Zip Download</span>
            <i class="fa-solid fa-lock text-[10px] text-amber-400"></i>
          </button>
          <button onclick="triggerProFeature('Seamless Tiling Engine')" class="w-full text-left flex items-center justify-between p-2 rounded-lg hover:bg-slate-900 text-slate-400 hover:text-amber-400 transition">
            <span><i class="fa-solid fa-border-none text-[10px] mr-1.5"></i> Seamless Tiling Fixer</span>
            <i class="fa-solid fa-lock text-[10px] text-amber-400"></i>
          </button>
        </div>
      </div>

      <!-- EXTERNAL HUBS -->
      <div class="mt-6 pt-4 border-t border-slate-800/80">
        <div class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-2 px-2 flex items-center gap-1.5">
          <i class="fa-solid fa-globe text-[9px]"></i> External Asset Hubs
        </div>
        <div class="space-y-1 text-xs">
          <a href="https://polyhaven.com/textures" target="_blank" class="flex items-center justify-between p-2 rounded-lg hover:bg-slate-900 text-slate-400 hover:text-brand-400 transition">
            <span><i class="fa-solid fa-cube text-[10px] mr-1.5"></i> PolyHaven</span>
            <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
          </a>
          <a href="https://ambientcg.com/list?sort=popular" target="_blank" class="flex items-center justify-between p-2 rounded-lg hover:bg-slate-900 text-slate-400 hover:text-brand-400 transition">
            <span><i class="fa-solid fa-layer-group text-[10px] mr-1.5"></i> ambientCG</span>
            <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
          </a>
          <a href="https://www.freepik.com" target="_blank" class="flex items-center justify-between p-2 rounded-lg hover:bg-slate-900 text-slate-400 hover:text-brand-400 transition">
            <span><i class="fa-solid fa-images text-[10px] mr-1.5"></i> Freepik</span>
            <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
          </a>
          <a href="https://www.pexels.com" target="_blank" class="flex items-center justify-between p-2 rounded-lg hover:bg-slate-900 text-slate-400 hover:text-brand-400 transition">
            <span><i class="fa-solid fa-camera text-[10px] mr-1.5"></i> Pexels</span>
            <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
          </a>
        </div>
      </div>
    </div>

    <!-- LEFT SIDEBAR BOTTOM CREATOR BOX -->
    <div class="mt-8 pt-4 border-t border-slate-800/80">
      <div class="bg-gradient-to-b from-slate-900/90 to-slate-950/90 p-4 rounded-2xl border border-slate-800 text-center shadow-2xl relative overflow-hidden group hover:border-brand-500/40 transition-all duration-300">
        <div class="w-10 h-10 rounded-xl bg-brand-500/10 text-brand-400 border border-brand-500/20 flex items-center justify-center mx-auto mb-2 text-base group-hover:scale-110 group-hover:rotate-12 transition-all duration-300">
          <i class="fa-solid fa-wand-magic-sparkles text-amber-400"></i>
        </div>
        <h4 class="text-xs font-bold text-white mb-1">Custom PBR Studio</h4>
        <p class="text-[10px] text-slate-400 mb-3 leading-relaxed">Drag photo to generate complete PBR map sets.</p>
        <a href="#pbr-studio" class="btn-glow block w-full bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-slate-950 font-bold py-2 rounded-xl text-xs transition-all duration-300 shadow-lg shadow-emerald-500/20">
          Create Texture
        </a>
      </div>
    </div>

  </aside>

  <!-- MAIN CONTENT AREA -->
  <main class="flex-grow p-4 sm:p-6 lg:p-8 max-w-7xl mx-auto w-full">

    <!-- Toolbar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-8 border-b border-slate-800/80 pb-5">
      <div>
        <h1 class="text-2xl font-extrabold text-white tracking-tight flex items-center gap-2.5">
          <span id="current-category-name" class="font-display uppercase tracking-wide bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent">All PBR Textures</span>
        </h1>
        <p class="text-xs text-slate-400 mt-1" id="current-category-desc">Streaming studio assets & Sketchfab 3D models.</p>
      </div>

      <div class="relative w-full sm:w-80 group">
        <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-500 text-xs group-focus-within:text-brand-400 transition-colors"></i>
        <input
                type="text"
                id="asset-search"
                placeholder="Search e.g. 'car', 'wood', 'mech'..."
                class="w-full bg-slate-950/90 border border-slate-800 rounded-xl pl-9 pr-4 py-2.5 text-xs text-slate-200 placeholder-slate-500 focus:outline-none focus:border-brand-500/80 focus:ring-1 focus:ring-brand-500/50 transition-all duration-300 shadow-inner"
        />
      </div>
    </div>

    <!-- Loading State -->
    <div id="loading-spinner" class="py-28 text-center animate-pulse">
      <i class="fa-solid fa-circle-notch fa-spin text-4xl text-brand-500 mb-4"></i>
      <p class="text-xs text-slate-400 font-mono tracking-wider">Fetching studio assets from cloud repositories...</p>
    </div>

    <!-- ASSETS GRID -->
    <div id="asset-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6 hidden">
      <!-- Rendered via JavaScript -->
    </div>

    <!-- LOAD MORE BUTTON -->
    <div class="text-center mt-12 mb-8 hidden" id="load-more-box">
      <button onclick="loadMoreAssets()" class="btn-glow bg-slate-900 hover:bg-slate-800 text-slate-200 hover:text-white font-bold border border-slate-700/80 hover:border-brand-500 px-8 py-3 rounded-2xl text-xs transition-all duration-300 shadow-xl">
        <i class="fa-solid fa-arrows-rotate mr-2 text-brand-400"></i> Load More Stream Assets
      </button>
    </div>

    <!-- ================= PBR GENERATOR STUDIO SECTION ================= -->
    <section id="pbr-studio" class="mt-20 pt-10 border-t border-slate-800/80 scroll-mt-20">
      <div class="mb-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div>
          <span class="text-brand-400 text-xs font-mono font-bold uppercase tracking-wider inline-flex items-center gap-1.5"><i class="fa-solid fa-flask text-amber-400"></i> Creator Studio</span>
          <h2 class="text-2xl font-bold text-white tracking-tight mt-1">Interactive PBR Texture Engine & 3D Viewport</h2>
          <p class="text-xs text-slate-400 mt-1">Upload any photo to auto-generate PBR channels and view live texture mapping on 3D meshes.</p>
        </div>

        <!-- PRO SEAMLESS TILING TOGGLE -->
        <div class="bg-slate-950/90 border border-slate-800 p-2.5 rounded-2xl flex items-center gap-3">
          <span class="text-xs font-semibold text-slate-300 flex items-center gap-1.5"><i class="fa-solid fa-border-none text-amber-400 text-xs"></i> Seamless Tiling:</span>
          <button onclick="triggerProFeature('Seamless Tiling Engine')" class="bg-slate-900 border border-amber-500/40 text-amber-400 px-3 py-1 rounded-xl text-xs font-bold flex items-center gap-1.5 hover:bg-amber-500/10 transition">
            <i class="fa-solid fa-lock text-[10px]"></i> Enable PRO
          </button>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">

        <div class="lg:col-span-4 bg-slate-950/80 border border-slate-800/80 p-5 rounded-2xl space-y-4 shadow-xl backdrop-blur-lg">
          <div
                  id="drop-zone"
                  onclick="document.getElementById('image-input').click()"
                  class="border-2 border-dashed border-slate-800 hover:border-brand-500/60 bg-slate-900/60 hover:bg-slate-900/90 rounded-xl p-6 text-center cursor-pointer transition-all duration-300 flex flex-col items-center justify-center gap-2 group"
          >
            <i class="fa-solid fa-cloud-arrow-up text-3xl text-slate-500 group-hover:text-brand-400 group-hover:scale-110 transition-all duration-300"></i>
            <p class="text-xs text-slate-300 font-semibold group-hover:text-white transition-colors">Drag & Drop Image Here</p>
            <p class="text-[10px] text-slate-500 font-mono">Supports JPG, PNG, WEBP</p>
            <input type="file" id="image-input" accept="image/*" class="hidden" onchange="handleFileSelect(event)">
          </div>

          <div>
            <label class="block text-[11px] font-medium text-slate-400 mb-1">Material Name</label>
